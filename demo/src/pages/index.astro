---
// demo/src/pages/index.astro
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>astro-integrations — @shiftescape</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:        #07090f;
        --bg-card:   #0c1018;
        --bg-pill:   #131925;
        --border:    #1c2436;
        --border-hi: #273045;
        --text:      #dde4f0;
        --sub:       #99aac4;
        --muted:     #4d607a;

        --sky:    #38bdf8;
        --violet: #a78bfa;
        --emerald:#34d399;
        --amber:  #f59e0b;
        --rose:   #fb7185;

        --sky-dim:    rgba(56,189,248,.07);
        --violet-dim: rgba(167,139,250,.07);
        --emerald-dim:rgba(52,211,153,.07);

        --amber:    #f59e0b;
        --islands-accent: #f59e0b;
        --islands-dim:    rgba(245,158,11,.07);

        --rose:         #fb7185;
        --i18n-accent:  #fb7185;
        --i18n-dim:     rgba(251,113,133,.07);

        --ff:  'IBM Plex Sans', sans-serif;
        --ffm: 'IBM Plex Mono', monospace;
        --r-sm: 6px; --r-md: 10px; --r-lg: 16px; --r-xl: 20px;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--ff);
        font-size: 16px;
        line-height: 1.7;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      /* subtle dot grid background */
      body::before {
        content: '';
        position: fixed; inset: 0;
        background-image: radial-gradient(circle, #1c2436 1px, transparent 1px);
        background-size: 32px 32px;
        opacity: .35;
        pointer-events: none; z-index: 0;
      }

      /* page glow */
      body::after {
        content: '';
        position: fixed;
        top: -200px; left: 50%; transform: translateX(-50%);
        width: 800px; height: 600px;
        background: radial-gradient(ellipse, rgba(56,189,248,.04) 0%, transparent 70%);
        pointer-events: none; z-index: 0;
      }

      .page {
        position: relative; z-index: 1;
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ── Nav ── */
      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 0 24px;
        border-bottom: 1px solid var(--border);
      }

      .nav-logo {
        font-family: var(--ffm);
        font-size: 14px; font-weight: 600;
        color: var(--text); text-decoration: none;
        display: flex; align-items: center; gap: 8px;
      }

      .nav-logo-badge {
        font-size: 11px; font-weight: 400;
        color: var(--muted);
        background: var(--bg-pill);
        border: 1px solid var(--border);
        padding: 2px 8px; border-radius: 100px;
      }

      .nav-links { display: flex; gap: 4px; list-style: none; }

      .nav-links a {
        color: var(--sub); text-decoration: none;
        font-size: 14px; padding: 6px 12px;
        border-radius: var(--r-sm);
        transition: color .15s, background .15s;
      }
      .nav-links a:hover { color: var(--text); background: var(--bg-pill); }

      /* ── Hero ── */
      .hero { padding: 96px 0 80px; }

      .hero-pill {
        display: inline-flex; align-items: center; gap: 7px;
        background: var(--bg-pill);
        border: 1px solid var(--border-hi);
        border-radius: 100px;
        padding: 6px 14px 6px 10px;
        font-size: 13px; color: var(--sub);
        margin-bottom: 32px;
      }

      .hero-pill-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: var(--emerald);
        box-shadow: 0 0 8px var(--emerald);
        animation: blink 2.4s ease-in-out infinite;
      }

      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

      .hero h1 {
        font-size: clamp(44px, 7vw, 72px);
        font-weight: 700;
        line-height: 1.0;
        letter-spacing: -.04em;
        color: var(--text);
        margin-bottom: 24px;
      }

      .hero h1 em {
        font-style: normal;
        background: linear-gradient(120deg, var(--sky) 0%, var(--violet) 60%, var(--emerald) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-sub {
        font-size: 18px; font-weight: 400;
        color: var(--sub); max-width: 540px;
        line-height: 1.65; margin-bottom: 40px;
      }

      .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        font-family: var(--ff);
        font-size: 14px; font-weight: 500;
        padding: 11px 20px;
        border-radius: var(--r-md);
        text-decoration: none;
        border: 1px solid transparent;
        transition: all .15s; cursor: pointer;
      }

      .btn-ghost {
        color: var(--sub);
        border-color: var(--border-hi);
        background: transparent;
      }
      .btn-ghost:hover { color: var(--text); background: var(--bg-pill); }

      /* ── Section ── */
      .section { padding: 80px 0; border-top: 1px solid var(--border); }

      .section-eyebrow {
        font-family: var(--ffm);
        font-size: 11px; font-weight: 500;
        text-transform: uppercase; letter-spacing: .14em;
        color: var(--muted); margin-bottom: 14px;
      }

      .section-title {
        font-size: clamp(26px, 3.5vw, 36px);
        font-weight: 700;
        letter-spacing: -.03em;
        color: var(--text); margin-bottom: 12px; line-height: 1.1;
      }

      .section-desc {
        color: var(--sub); font-size: 16px;
        max-width: 520px; margin-bottom: 48px; line-height: 1.65;
      }

      /* ── Package cards ── */
      .packages {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
      }
      @media (max-width: 600px) { .packages { grid-template-columns: 1fr; } }
      @media (max-width: 500px) { .packages { grid-template-columns: 1fr; } }

      .pkg-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-xl);
        padding: 28px 26px 24px;
        position: relative; overflow: hidden;
        transition: border-color .2s, transform .2s;
        display: flex; flex-direction: column;
      }
      .pkg-card:hover { border-color: var(--border-hi); transform: translateY(-2px); }
      .pkg-card::before {
        content: ''; position: absolute; inset: 0; opacity: 0;
        transition: opacity .3s; pointer-events: none;
      }
      .pkg-card:hover::before { opacity: 1; }
      .pkg-card.budget::before { background: radial-gradient(ellipse at top left, var(--sky-dim), transparent 55%); }
      .pkg-card.env::before    { background: radial-gradient(ellipse at top left, var(--violet-dim), transparent 55%); }
      .pkg-card.routes::before  { background: radial-gradient(ellipse at top left, var(--emerald-dim), transparent 55%); }
      .pkg-card.islands::before { background: radial-gradient(ellipse at top left, var(--islands-dim), transparent 55%); }
      .pkg-card.i18n::before    { background: radial-gradient(ellipse at top left, var(--i18n-dim),    transparent 55%); }

      .pkg-icon {
        width: 44px; height: 44px;
        border-radius: var(--r-md);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 18px; font-size: 20px;
      }
      .pkg-card.budget .pkg-icon { background: var(--sky-dim);     border: 1px solid rgba(56,189,248,.25); }
      .pkg-card.env    .pkg-icon { background: var(--violet-dim);  border: 1px solid rgba(167,139,250,.25); }
      .pkg-card.routes .pkg-icon { background: var(--emerald-dim); border: 1px solid rgba(52,211,153,.25); }
      .pkg-card.islands .pkg-icon { background: var(--islands-dim);   border: 1px solid rgba(245,158,11,.25); }
      .pkg-card.i18n    .pkg-icon { background: var(--i18n-dim);     border: 1px solid rgba(251,113,133,.25); }

      .pkg-name {
        font-family: var(--ffm);
        font-size: 11px; font-weight: 500;
        margin-bottom: 10px; letter-spacing: .01em;
      }
      .pkg-card.budget .pkg-name { color: var(--sky); }
      .pkg-card.env    .pkg-name { color: var(--violet); }
      .pkg-card.routes .pkg-name { color: var(--emerald); }
      .pkg-card.islands .pkg-name { color: var(--islands-accent); }
      .pkg-card.i18n    .pkg-name { color: var(--i18n-accent); }

      .pkg-title {
        font-size: 20px; font-weight: 700;
        color: var(--text); margin-bottom: 10px;
        letter-spacing: -.025em; line-height: 1.2;
      }

      .pkg-desc {
        font-size: 14px; color: var(--sub);
        line-height: 1.65; margin-bottom: 20px; flex: 1;
      }

      .pkg-pills { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; }

      .pill {
        font-size: 11px; font-weight: 500;
        padding: 3px 10px; border-radius: 100px;
        background: var(--bg-pill);
        border: 1px solid var(--border-hi);
        color: var(--sub);
      }

      .pkg-links { display: flex; gap: 8px; }

      .pkg-link {
        font-size: 13px; color: var(--muted);
        text-decoration: none; padding: 6px 12px;
        border-radius: var(--r-sm);
        border: 1px solid var(--border);
        transition: all .15s;
      }
      .pkg-link:hover { color: var(--text); border-color: var(--border-hi); background: var(--bg-pill); }

      /* ── Terminal ── */
      .terminal {
        background: #03050b;
        border: 1px solid var(--border);
        border-radius: var(--r-xl); overflow: hidden;
        margin-top: 48px;
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
      }

      .terminal-bar {
        display: flex; align-items: center; gap: 7px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        background: #07090f;
      }

      .t-dot { width: 11px; height: 11px; border-radius: 50%; }
      .t-dot.red    { background: #ff5f57; }
      .t-dot.yellow { background: #febc2e; }
      .t-dot.green  { background: #28c840; }

      .terminal-title {
        font-family: var(--ffm);
        font-size: 12px; color: var(--muted);
        margin-left: 8px; flex: 1; text-align: center;
      }

      .terminal-body {
        padding: 24px 28px;
        font-family: var(--ffm);
        font-size: 13px; line-height: 2;
        overflow-x: auto;
      }

      .t-dim   { color: var(--muted); }
      .t-key   { color: var(--sky); }
      .t-str   { color: var(--emerald); }
      .t-ok    { color: var(--emerald); }
      .t-warn  { color: var(--amber); }
      .t-err   { color: var(--rose); }
      .t-info  { color: var(--sky); }
      .t-label { color: var(--violet); font-weight: 600; }

      /* ── Features ── */
      .features {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px; margin-top: 48px;
      }
      @media (max-width: 700px) { .features { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 440px) { .features { grid-template-columns: 1fr; } }

      .feat {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 22px 22px 20px;
        transition: border-color .2s;
      }
      .feat:hover { border-color: var(--border-hi); }

      .feat-icon { font-size: 22px; margin-bottom: 12px; display: block; }

      .feat-title {
        font-size: 15px; font-weight: 600;
        color: var(--text); margin-bottom: 6px;
        letter-spacing: -.01em;
      }

      .feat-desc { font-size: 13px; color: var(--sub); line-height: 1.6; }
      .feat-desc code {
        font-family: var(--ffm); font-size: 12px;
        background: var(--bg-pill); padding: 1px 5px;
        border-radius: 4px; color: var(--text);
      }

      /* ── Install ── */
      .install-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px; margin-top: 48px;
      }
      @media (max-width: 500px) { .install-grid { grid-template-columns: 1fr; } }
      

      .install-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r-xl); overflow: hidden;
        transition: border-color .2s;
      }
      .install-card:hover { border-color: var(--border-hi); }

      .install-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; justify-content: space-between;
      }

      .install-pkg {
        font-family: var(--ffm);
        font-size: 12px; font-weight: 600;
      }
      .install-card.budget .install-pkg { color: var(--sky); }
      .install-card.env    .install-pkg { color: var(--violet); }
      .install-card.routes .install-pkg  { color: var(--emerald); }
      .install-card.islands .install-pkg { color: var(--islands-accent); }
      .install-card.i18n    .install-pkg { color: var(--i18n-accent); }

      .install-badge {
        font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: .08em;
        padding: 3px 8px; border-radius: 100px;
        background: var(--bg-pill);
        border: 1px solid var(--border-hi);
        color: var(--muted);
      }

      .install-body {
        padding: 16px 20px;
        display: flex; flex-direction: column; gap: 8px;
      }

      .install-cmd { display: flex; flex-direction: column; align-items: stretch; gap: 8px; width: 100%; }

      .install-pm {
        font-family: var(--ffm);
        font-size: 11px; color: var(--muted);
        display: block;
      }

      .install-code {
        font-family: var(--ffm);
        color: var(--text);
        background: var(--bg-pill);
        border: 1px solid var(--border);
        border-radius: var(--r-sm);
        padding: 7px 12px;
        font-size: 12px; overflow-x: auto;
        white-space: nowrap;
        width: 100%;
        box-sizing: border-box;
      }
      .install-card.budget .install-code span { color: var(--sky); }
      .install-card.env    .install-code span { color: var(--violet); }
      .install-card.routes .install-code span  { color: var(--emerald); }
      .install-card.islands .install-code span { color: var(--islands-accent); }
      .install-card.i18n    .install-code span { color: var(--i18n-accent); }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 36px 0 56px;
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; flex-wrap: wrap;
      }

      .footer-left { font-size: 14px; color: var(--muted); }
      .footer-left a { color: var(--sub); text-decoration: none; }
      .footer-left a:hover { color: var(--text); }

      .footer-links { display: flex; gap: 20px; list-style: none; }
      .footer-links a {
        font-size: 14px; color: var(--muted);
        text-decoration: none; transition: color .15s;
      }
      .footer-links a:hover { color: var(--text); }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- Nav -->
      <nav>
        <a href="/" class="nav-logo">
          @shiftescape
          <span class="nav-logo-badge">astro-integrations</span>
        </a>
        <ul class="nav-links">
          <li><a href="https://github.com/shiftEscape" target="_blank" rel="noopener">GitHub ↗</a></li>
          <li><a href="https://www.npmjs.com/~shiftescape" target="_blank" rel="noopener">npm ↗</a></li>
        </ul>
      </nav>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-pill">
          <span class="hero-pill-dot"></span>
          4 packages · Open Source · MIT license
        </div>
        <h1>Astro integrations<br />that <em>actually help.</em></h1>
        <p class="hero-sub">
          Focused, zero-dependency integrations for Astro. Each one solves a real developer pain point — built-in to your workflow, invisible in production.
        </p>
        <div class="hero-ctas">
          <a href="https://github.com/shiftEscape" class="btn btn-ghost" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="https://www.npmjs.com/~shiftescape" class="btn btn-ghost" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm19.2 19.2H4.8V4.8h14.4v14.4zM8 8v8h3.2V9.6h1.6V16H16V8H8z"/></svg>
            View on npm
          </a>
        </div>
      </section>

      <!-- Packages -->
      <section class="section">
        <p class="section-eyebrow">Packages</p>
        <h2 class="section-title">Four tools. Zero fluff.</h2>
        <p class="section-desc">Each integration is focused, dependency-free, and designed to disappear — showing up only when you need it.</p>

        <div class="packages">
          <div class="pkg-card budget">
            <div class="pkg-icon">📦</div>
            <div class="pkg-name">@shiftescape/astro-bundle-budget</div>
            <div class="pkg-title">Bundle Budget</div>
            <p class="pkg-desc">Audits your JS and CSS bundle sizes at build time. Set per-file or per-page thresholds and fail CI automatically when you exceed them.</p>
            <div class="pkg-pills">
              <span class="pill">build-time</span>
              <span class="pill">CI-ready</span>
              <span class="pill">gzip/brotli</span>
              <span class="pill">per-page</span>
            </div>
            <div class="pkg-links">
              <a href="https://www.npmjs.com/package/@shiftescape/astro-bundle-budget" target="_blank" rel="noopener" class="pkg-link">npm ↗</a>
              <a href="https://github.com/shiftEscape/astro-bundle-budget" target="_blank" rel="noopener" class="pkg-link">docs ↗</a>
            </div>
          </div>

          <div class="pkg-card env">
            <div class="pkg-icon">🔍</div>
            <div class="pkg-name">@shiftescape/astro-env-inspector</div>
            <div class="pkg-title">Env Inspector</div>
            <p class="pkg-desc">Dev toolbar panel that shows all your environment variables — grouped, masked, and searchable. Active only in dev mode, zero production footprint.</p>
            <div class="pkg-pills">
              <span class="pill">dev-only</span>
              <span class="pill">masked values</span>
              <span class="pill">leak detection</span>
            </div>
            <div class="pkg-links">
              <a href="https://www.npmjs.com/package/@shiftescape/astro-env-inspector" target="_blank" rel="noopener" class="pkg-link">npm ↗</a>
              <a href="https://github.com/shiftEscape/astro-env-inspector" target="_blank" rel="noopener" class="pkg-link">docs ↗</a>
            </div>
          </div>

          <div class="pkg-card routes">
            <div class="pkg-icon">🗺</div>
            <div class="pkg-name">@shiftescape/astro-toolbar-routes</div>
            <div class="pkg-title">Route Map</div>
            <p class="pkg-desc">Dev toolbar route map — a live, clickable list of every route in your project. Jump to any page without leaving the browser.</p>
            <div class="pkg-pills">
              <span class="pill">dev-only</span>
              <span class="pill">clickable nav</span>
              <span class="pill">live updates</span>
            </div>
            <div class="pkg-links">
              <a href="https://www.npmjs.com/package/@shiftescape/astro-toolbar-routes" target="_blank" rel="noopener" class="pkg-link">npm ↗</a>
              <a href="https://github.com/shiftEscape/astro-toolbar-routes" target="_blank" rel="noopener" class="pkg-link">docs ↗</a>
            </div>
          </div>
          <div class="pkg-card i18n">
            <div class="pkg-icon">🌐</div>
            <div class="pkg-name">@shiftescape/astro-i18n-toolkit</div>
            <div class="pkg-title">i18n Toolkit</div>
            <p class="pkg-desc">Dev toolbar i18n debugger — translation coverage map across all locales and a one-click locale switcher. Library-agnostic: works with any JSON/YAML setup.</p>
            <div class="pkg-pills">
              <span class="pill">dev-only</span>
              <span class="pill">coverage map</span>
              <span class="pill">locale switcher</span>
            </div>
            <div class="pkg-links">
              <a href="https://www.npmjs.com/package/@shiftescape/astro-i18n-toolkit" target="_blank" rel="noopener" class="pkg-link">npm ↗</a>
              <a href="https://github.com/shiftEscape/astro-i18n-toolkit" target="_blank" rel="noopener" class="pkg-link">docs ↗</a>
            </div>
          </div>

        </div>
      </section>

      <!-- Bundle Budget preview -->
      <section class="section">
        <p class="section-eyebrow">astro-bundle-budget</p>
        <h2 class="section-title">Know your bundle.<br />Before it ships.</h2>
        <p class="section-desc">Runs after every <code style="font-family:var(--ffm);font-size:14px;background:var(--bg-pill);padding:2px 7px;border-radius:4px">astro build</code> and prints a full asset table with per-page breakdown. Set a budget — it exits 1 on violation.</p>

        <div class="terminal">
          <div class="terminal-bar">
            <span class="t-dot red"></span><span class="t-dot yellow"></span><span class="t-dot green"></span>
            <span class="terminal-title">astro build</span>
          </div>
